{
  "name": "@addonweb/claude-toolkit",
  "version": "1.0.0",
  "description": "Production-ready Claude Skills, MCP servers, and agent packs by AddonWeb",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./skills/*": {
      "import": "./dist/skills/*.js",
      "types": "./dist/skills/*.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["claude", "skills", "mcp", "ai", "gemini", "toolkit", "iot", "gst", "india"],
  "author": "AddonWeb Solutions <addonwebsolutions.ai@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/addonwebsolutionsai-droid/addon90days"
  },
  "homepage": "https://toolkit.addonweb.io",
  "bugs": { "email": "support@addonweb.io" },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0"
  },
  "files": ["dist", "README.md"],
  "engines": { "node": ">=20.0.0" },
  "publishConfig": { "access": "public" }
}
